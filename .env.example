# 1230-UI Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Server Configuration
# =============================================================================

# Port for the web interface
PORT=3001

# Note: NODE_ENV is set automatically by Vite during build (production)
# or by running `npm run dev` (development). Do not set it in .env.

# =============================================================================
# Hermes Database
# =============================================================================

# Path to Hermes state database (read-only access)
# Default: ~/.hermes/state.db
HERMES_DB_PATH=/home/USERNAME/.hermes/state.db

# =============================================================================
# 1230-UI Database
# =============================================================================

# Path to UI database (read-write, stores UI-specific data)
# Default: ./data/1230-ui.db (relative to project root)
UI_DB_PATH=./data/1230-ui.db

# =============================================================================
# Hermes API Configuration
# =============================================================================

# Hermes API server URL
HERMES_API_URL=http://127.0.0.1:8642

# Hermes API authentication key
# IMPORTANT: Change this to a secure random string
HERMES_API_KEY=your-secret-api-key-here

# =============================================================================
# Python Environment
# =============================================================================

# Path to Python interpreter from Hermes virtual environment
# Required for running Python scripts (save_messages.py, sync_providers.py, etc.)
# Default: python3 (system Python)
HERMES_PYTHON_PATH=/home/USERNAME/.hermes/hermes-agent/venv/bin/python

# =============================================================================
# Hermes Agent Installation
# =============================================================================

# Path to Hermes Agent installation directory
# Used for running hermes CLI commands (hermes update, hermes doctor)
# Default: /usr/local/lib/hermes-agent
HERMES_AGENT_PATH=/usr/local/lib/hermes-agent

# =============================================================================
# CORS Configuration
# =============================================================================

# Trusted origins (comma-separated)
# Default: http://localhost:3001
CORS_ORIGINS=http://localhost:3001,https://your-domain.com

# =============================================================================
# Likes (Mattermost webhook)
# =============================================================================

# Incoming webhook URL for the Likes channel in Mattermost
# Create at: Mattermost → Integrations → Incoming Webhooks → Add
# Leave unset to disable the like feature
LIKES_WEBHOOK_URL=https://connect.iampingvin.com/hooks/your-token-here

# Per-user cooldown in seconds (default 3600 = 1 hour)
LIKES_COOLDOWN_SEC=3600

# =============================================================================
# File Retention Policy
# =============================================================================

# Files are automatically deleted after this many days
# Set to 0 to disable auto-deletion
FILE_RETENTION_DAYS=30

# =============================================================================
# OpenCode Executor (optional)
# =============================================================================

# URL of the OpenCode daemon (opencode serve)
# Default: http://127.0.0.1:4097
# OPENCODE_URL=http://127.0.0.1:4097

# Optional Basic Auth credentials for the OpenCode daemon
# Leave unset if the daemon runs without authentication
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=

# Auto-approve OpenCode tool permission requests (bash/edit/read/…).
# When "1" (default), 1230UI responds "allow once" to every permission.updated
# event so tools run inline in the chat. SECURITY: this lets the model execute
# shell commands and edit files (as the daemon user, in the --worktree dir).
# Set to "0" to disable — tools will then NOT run from 1230UI (they still work
# in the OpenCode web UI on the daemon port).
OPENCODE_AUTO_APPROVE_TOOLS=1

# =============================================================================
# Cloud Connect (WebDAV)
# =============================================================================

# Encryption key for stored WebDAV credentials (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CLOUD_CONNECT_KEY=

# =============================================================================
# Tududi Integration (optional)
# =============================================================================

# Base URL of the Tududi instance (no trailing slash)
# Default: https://todo.thinkout.ru
# These are INITIAL DEFAULTS only — once 1230-UI is running, edit them at runtime
# via Settings → Tududi (stored encrypted in the system_settings table).
# TUDUDI_API_URL=https://todo.thinkout.ru

# Tududi API bearer token (starts with tt_)
# Create in Tududi UI: Profile → Settings → API Keys
# Leave unset to configure via the Settings UI instead.
# TUDUDI_API_TOKEN=tt_your_token_here

# HTTP timeout for Tududi API calls in ms (default 15000)
# TUDUDI_TIMEOUT_MS=15000
